# Copy this file to .env (in this same repo-root folder) and fill in the values.
# .env is gitignored and must never be committed.

# Deepgram — speech-to-text (used by the Pipecat server)
DEEPGRAM_API_KEY=

# OpenAI — the language model that writes replies (used by the Pipecat server)
OPENAI_API_KEY=

# Where the Pipecat server reaches the inference server. Default is fine locally.
QWEN_TTS_URI=ws://localhost:8000/tts
